% Here is TeX material that gets inserted after \input webmac
\def\hang{\hangindent 3em\indent\ignorespaces}
\font\ninerm=cmr9
\let\mc=\ninerm % medium caps for names like ADA
\def\ADA{{\mc ADA}}
\def\ab{$\.|\ldots\.|$} % ada brackets (|...|)
\def\v{\.{\char'174}} % vertical (|) in typewriter font
\def\dleft{[\![} \def\dright{]\!]} % double brackets
\mathchardef\RA="3221 % right arrow
\mathchardef\BA="3224 % double arrow
\def\({} % kludge for alphabetizing certain module names
 
\def\title{AWEAVE}
\def\contentspagenumber{13} % should be odd
\def\topofcontents{\null\vfill
  \titlefalse % include headline on the contents page
  \def\rheader{\mainfont Appendix D\hfil \contentspagenumber}
  \centerline{\titlefont The {\ttitlefont AWEAVE} processor}
  \vskip 15pt
  \centerline{(based on {\tt WEAVE} Version 2.8)}
  \centerline{\ninerm[ADA-Version 1.0]}
  \vfill}
\pageno=\contentspagenumber \advance\pageno by 1
 
@* Introduction.
This program converts an \.{AWEB} file to a \TeX\ file. It was written
(initially in {\mc PASCAL})
by D. E. Knuth in October, 1981; a somewhat similar {\mc SAIL} program had
been developed in March, 1979, although the earlier program used a top-down
parsing method that is quite different from the present scheme.
 
The conversion from {\mc PASCAL} to {\mc ADA} has been done by
U. Schweigert in May, 1988.

The ``banner line'' defined here should be changed whenever \.{AWEAVE}
is modified.
 
@d banner=="This is AWEAVE, Version 1.1 (NRaD Version)"
 
@ The program consists of several packages that are declared right now;
each of these packages and both the specification and the body of
the packages are send to a seperate file. The main program itself
is declared later.

@ The first package we declare is called |int_number_io| and enables us
to output integer numbers. Further we declare a package |data_structures|,
which will contain all the global constants, types, variables, and some
procedures used throughout the program; it will (nearly) contain code of 
the sections ``The character set'' and ``Data structures.''

@a@~data_str.a@>
@.data_str.a@>
with TEXT_IO;
with int_number_io;
with TEXT_IO;
package data_structures is
  @<Types and objects visible from |data_structures|@>@;
  @<Specification of procedures visible from |data_structures|@>@;
  procedure initialize;
end data_structures;
@#
@~data_str_b.a@>
@.data_str_b.a@>
with input_output; @+use input_output;
package body data_structures is
  @<Procedures in |data_structures|@>@;
  procedure @!initialize is
  begin
  @<Set initial values@>@;
  end initialize;
end data_structures;

@ The following package, called |input_output|, is responsible for the
input/output features needed by \.{AWEAVE}, and for the error handling.
It will contain code of sections ``Input and output'' and ``Reporting
errors to the user.''

@a
@~in_out.a@>
@.in_out.a@>
with TEXT_IO;
with data_structures; @+use data_structures;
package input_output is
  @<Specification of procedures visible from |input_output|@>@;
end input_output;
@#
@~in_out_b.a@>
@.in_out_b.a@>
with TEXT_IO,int_number_io;
package body input_output is
  @<Procedures in |input_output|@>@;
end input_output;

@ Additionally we have a package |searching|, which contains the code of
sections ``Searching for identifiers'' and ``Searching for module names.''

@a
@~search.a@>
@.search.a@>
with data_structures; @+use data_structures;
package searching is
  @<Specification of procedures visible from |searching|@>@;
end searching;
@#
@~search_b.a@>
@.search_b.a@>
with TEXT_IO;
with input_output; @+use input_output;
package body searching is
  @<Procedures in |searching|@>@;
end searching;

@ The first of the major packages will manage the input process of
\.{AWEAVE} and contains code of sections ``Lexical Scanning''
and ``Inputting the next token.''

@a
@~lex_scan.a@>
@.lex_scan.a@>
with data_structures; @+use data_structures;
package lexical_scanning is
  @<Specification of procedures visible from |lexical_scanning|@>@;
end lexical_scanning;
@#
@~lex_scan_b.a@>
@.lex_scan_b.a@>
with TEXT_IO,int_number_io;
with input_output; @+use input_output;
with searching; @+use searching;
package body lexical_scanning is
  @<Procedures in |lexical_scanning|@>@;
end lexical_scanning;

@ The next package is responsible for the first phase of \.{AWEAVE} and
contains code of section ``Phase one processing.''
@a@~phase_1.a@>
@.phase_1.a@>
with data_structures; @+use data_structures;
package first_phase is
  @<Specification of procedures visible from |first_phase|@>@;
end first_phase;
@#
@~phase_1_b.a@>
@.phase_1_b.a@>
with TEXT_IO,int_number_io;
with input_output; @+use input_output;
with searching; @+use searching;
with lexical_scanning; @+use lexical_scanning;
package body first_phase is
  @<Procedures in |first_phase|@>@;
end first_phase;

@ This package provides the output features needed in the second and
third phase of \.{AWEAVE} and contains code of sections ``Low-level
output routines'' and ``Routines that copy \TeX\ material.''
@a@~output.a@>
@.output.a@>
with data_structures; @+use data_structures;
package output is
  @<Specification of procedures visible from |output|@>@;
end output;
@#
@~output_b.a@>
@.output_b.a@>
with TEXT_IO,int_number_io;
with input_output; @+use input_output;
with lexical_scanning; @+use lexical_scanning;
package body output is
  @<Procedures in |output|@>@;
end output;

@ Here's a package that handles the parsing of \ADA-texts containing code
of sections ``Parsing,'' ``Implementing the productions,'' and
``Initializing the scraps.''
@a@~parsing.a@>
@.parsing.a@>
with data_structures; @+use data_structures;
package parsing is
  @<Specification of procedures visible from |parsing|@>@;
end parsing;
@#
@~parsing_b.a@>
@.parsing_b.a@>
with TEXT_IO,int_number_io;
with input_output; @+use input_output;
with searching; @+use searching;
with lexical_scanning; @+use lexical_scanning;
with output; @+use output;
package body parsing is
  @<Procedures in |parsing|@>@;
end parsing;

@ Now there's a package for handling phase two of \.{AWEAVE} containing
code of sections ``Output of tokens'' and ``Phase two processing.''
@a@~phase_2.a@>
@.phase_2.a@>
with data_structures; @+use data_structures;
package second_phase is
  @<Specification of procedures visible from |second_phase|@>@;
end second_phase;
@#
@~phase_2_b.a@>
@.phase_2_b.a@>
with TEXT_IO,int_number_io;
with input_output; @+use input_output;
with searching; @+use searching;
with lexical_scanning; @+use lexical_scanning;
with output; @+use output;
with parsing; @+use parsing;
package body second_phase is
  @<Procedures in |second_phase|@>@;
end second_phase;

@ Finally the last package handles the third phase of \.{AWEAVE} by
means of ``Phase three processing.''
@a@~phase_3.a@>
@.phase_3.a@>
with data_structures; @+use data_structures;
package third_phase is
  @<Specification of procedures visible from |third_phase|@>@;
end third_phase;
@#
@~phase_3_b.a@>
@.phase_3_b.a@>
with TEXT_IO,int_number_io;
with input_output; @+use input_output;
with output; @+use output;
with second_phase; @+use second_phase;
package body third_phase is
  @<Procedures in |third_phase|@>@;
end third_phase;
 

@ Some of this code is optional for use when
statistics about \.{AWEAVE}'s memory usage are desired;
such material is enclosed between the delimiters |stat| and |tats|.
Other material is optional when a somewhat optimal code is wanted;
such is delimited by |optim| and |mitpo|.
 
@d stat==@{ {change this to `$\\{stat}\equiv\null$'
  when gathering usage statistics}
@d tats==@t@>@} {change this to `$\\{tats}\equiv\null$'
  when gathering usage statistics}
@f stat==declare
@f tats==end
@d optim==@{     {change this to `$\\{optim}\equiv\null$' when optimal
		  code is desired}
@d mitpo==@t@>@} {change this to `$\\{mitpo}\equiv\null$' when optimal
		  code is desired}
@f optim==declare
@f mitpo==end
 
@ Here are some macros for common programming idioms.
 
@d incr(#) == #:=#+1 {increase a variable by unity}
@d decr(#) == #:=#-1 {decrease a variable by unity}
 
@ The following parameters are set big enough to handle \TeX, so they
should be sufficient for most applications of \.{AWEAVE}.
 
@<Types...@>=
@!max_bytes:constant := 45_000; {|1/ww| times the number of bytes in identifiers,
  index entries, and module names; must be less than 65\_536}
@!max_names:constant := 5_000; {number of identifiers, index entries, and module names;
  must be less than 10\_240}
@!max_modules:constant := 2_000;{greater than the total number of modules}
@!hash_size:constant := 353; {should be prime}
@!buf_size:constant := 100; {maximum length of input line}
@!longest_name:constant := 400; {module names shouldn't be longer than this}
@!long_buf_size:constant := 500; {|buf_size+longest_name|}
@!line_length:constant := 80; {lines of \TeX\ output have at most this many characters,
  should be less than 256}
@!max_refs:constant := 60_000; {number of cross references; must be less than 65\_536}
@!max_toks:constant := 60_000; {number of symbols in \ADA\ texts being parsed;
  must be less than 65\_536}
@!max_texts:constant := 10_000; {number of phrases in \ADA\ texts being parsed;
  must be less than 10\_240}
@!max_scraps:constant := 8_000; {number of tokens in \ADA\ texts being parsed}
@!stack_size:constant := 800; {number of simultaneous output levels}
 
@ A global variable called |history| will contain one of four values
at the end of every run: |spotless| means that no unusual messages were
printed; |harmless_message| means that a message of possible interest
was printed but no serious errors were detected; |error_message| means that
at least one error was found; |fatal_message| means that the program
terminated abnormally. The value of |history| does not influence the
behavior of the program; it is simply computed for the convenience
of systems that might want to use such information.
 
@d mark_harmless==if history=spotless then history:=harmless_message; 
                  end if@;
@d mark_error==history:=error_message@;
@d mark_fatal==history:=fatal_message@;
 
@<Types...@>=
type history_type is (@!spotless,@!harmless_message,@!error_message,
		      @!fatal_message);
@!history:history_type := spotless; {how bad was this run?}
 

@* The character set.
One of the main goals in the design of \.{AWEB} has been to make it readily
portable between a wide variety of computers. Yet \.{AWEB} by its very
nature must use a greater variety of characters than most computer
programs deal with, and character encoding is one of the areas in which
existing machines differ most widely from each other.
 
To resolve this problem, all input to \.{AWEAVE} and \.{ATANGLE} is converted
to an internal seven-bit code that is essentially standard ASCII, the 
``American Standard Code for Information Interchange.''  The conversion is 
done immediately when each character is read in. Conversely, characters are
converted from ASCII to the user's external representation just before
they are output.
 
Such an internal code is relevant to users of \.{AWEB} only because it is
the code used for preprocessed constants like \.{@@\'A\'}. If you are 
writing a program in \.{AWEB} that makes use of such one-character constants, you
should convert your input to ASCII form, like \.{AWEAVE} and \.{ATANGLE} do.
Otherwise \.{AWEB}'s internal coding scheme does not affect you.
@^ASCII code@>
 
Here is a table of the standard visible ASCII codes:
$$\def\:{\char\count255\global\advance\count255 by 1}
\count255='40
\vbox{
\hbox{\hbox to 40pt{\it\hfill0\/\hfill}%
\hbox to 40pt{\it\hfill1\/\hfill}%
\hbox to 40pt{\it\hfill2\/\hfill}%
\hbox to 40pt{\it\hfill3\/\hfill}%
\hbox to 40pt{\it\hfill4\/\hfill}%
\hbox to 40pt{\it\hfill5\/\hfill}%
\hbox to 40pt{\it\hfill6\/\hfill}%
\hbox to 40pt{\it\hfill7\/\hfill}}
\vskip 4pt
\hrule
\def\^{\vrule height 10.5pt depth 4.5pt}
\halign{\hbox to 0pt{\hskip -24pt\bn{8}{#0}\hfill}&\^
\hbox to 40pt{\tt\hfill#\hfill\^}&
&\hbox to 40pt{\tt\hfill#\hfill\^}\cr
04&\:&\:&\:&\:&\:&\:&\:&\:\cr\noalign{\hrule}
05&\:&\:&\:&\:&\:&\:&\:&\:\cr\noalign{\hrule}
06&\:&\:&\:&\:&\:&\:&\:&\:\cr\noalign{\hrule}
07&\:&\:&\:&\:&\:&\:&\:&\:\cr\noalign{\hrule}
10&\:&\:&\:&\:&\:&\:&\:&\:\cr\noalign{\hrule}
11&\:&\:&\:&\:&\:&\:&\:&\:\cr\noalign{\hrule}
12&\:&\:&\:&\:&\:&\:&\:&\:\cr\noalign{\hrule}
13&\:&\:&\:&\:&\:&\:&\:&\:\cr\noalign{\hrule}
14&\:&\:&\:&\:&\:&\:&\:&\:\cr\noalign{\hrule}
15&\:&\:&\:&\:&\:&\:&\:&\:\cr\noalign{\hrule}
16&\:&\:&\:&\:&\:&\:&\:&\:\cr\noalign{\hrule}
17&\:&\:&\:&\:&\:&\:&\:\cr}
\hrule width 280pt}$$
(Actually, of course, code \bn{8}{040} is an invisible blank space.)  Code
\bn{8}{136} was once an upward arrow (\.{\char'13}), and code \bn{8}{137} was
once a left arrow (\.^^X), in olden times when the first draft
of ASCII code was prepared; but \.{AWEB} works with today's standard
ASCII in which those codes represent circumflex and underline as shown.
 
@<Types...@>=
subtype ASCII_code is INTEGER range 0..127; {seven-bit numbers, a subrange
					     of the integers}
 
@ We shall use the name |text_char| to stand for the data type of the 
characters in the input and output files.  We shall also assume that 
|text_char| consists of the elements |text_char'FIRST|
through  |text_char'LAST|, inclusive. The following
definition should be adjusted if necessary.
@^system dependencies@>
 
@<Types...@>=
subtype text_char is CHARACTER; {the data type of characters in text files}
subtype text_file is TEXT_IO.FILE_TYPE; {file type consisting of |text_char|}

 
@ The \.{AWEAVE} and \.{ATANGLE} processors convert between ASCII code and
the user's external character set by means of arrays |xord| and |xchr|
that are analogous to \ADA's |POS| and |VAL| attributes.
@^ADA attributes@>
 
@<Types...@>=
@!xord: array (text_char) of ASCII_code;
  {specifies conversion of input characters}
@!xchr: array (ASCII_code) of text_char;
  {specifies conversion of output characters}
 
@ If we assume that every system using \.{AWEB} is able to read and write the
visible characters of standard ASCII (although not necessarily using the
ASCII codes to represent them), the following assignment statements 
initialize most of the |xchr| array properly, without needing any 
system-dependent changes. For example, the statement 
\.{xchr(8\#101\#):=\'A\';} that appears in the present \.{AWEB} file might be
encoded in, say, {\mc EBCDIC} code on the external medium on which it 
resides, but \.{ATANGLE} will convert from this external code to ASCII and
back again. Therefore the assignment statement \.{XCHR(8\#101\#):=\'A\';} 
will appear in the corresponding \ADA\ file, and \ADA\ will compile this 
statement so that |xchr(8#101#)| receives  the character \.A in the external 
(|text_char|) code. Note that it would be quite incorrect to say 
\.{xchr(8\#101\#):=\AT!\'A\';}, because |@'A'| is a constant of type 
|INTEGER|, not |CHARACTER|, and because we have |@'A'=65| regardless of the
external character set.
 
@<Set init...@>=
xchr(8#40#):=' ';
xchr(8#41#):='!';
xchr(8#42#):='"';
xchr(8#43#):='#';
xchr(8#44#):='$';
xchr(8#45#):='%';
xchr(8#46#):='&';
xchr(8#47#):=''';@/
xchr(8#50#):='(';
xchr(8#51#):=')';
xchr(8#52#):='*';
xchr(8#53#):='+';
xchr(8#54#):=',';
xchr(8#55#):='-';
xchr(8#56#):='.';
xchr(8#57#):='/';@/
xchr(8#60#):='0';
xchr(8#61#):='1';
xchr(8#62#):='2';
xchr(8#63#):='3';
xchr(8#64#):='4';
xchr(8#65#):='5';
xchr(8#66#):='6';
xchr(8#67#):='7';@/
xchr(8#70#):='8';
xchr(8#71#):='9';
xchr(8#72#):=':';
xchr(8#73#):=';';
xchr(8#74#):='<';
xchr(8#75#):='=';
xchr(8#76#):='>';
xchr(8#77#):='?';@/
xchr(8#100#):='@@';
xchr(8#101#):='A';
xchr(8#102#):='B';
xchr(8#103#):='C';
xchr(8#104#):='D';
xchr(8#105#):='E';
xchr(8#106#):='F';
xchr(8#107#):='G';@/
xchr(8#110#):='H';
xchr(8#111#):='I';
xchr(8#112#):='J';
xchr(8#113#):='K';
xchr(8#114#):='L';
xchr(8#115#):='M';
xchr(8#116#):='N';
xchr(8#117#):='O';@/
xchr(8#120#):='P';
xchr(8#121#):='Q';
xchr(8#122#):='R';
xchr(8#123#):='S';
xchr(8#124#):='T';
xchr(8#125#):='U';
xchr(8#126#):='V';
xchr(8#127#):='W';@/
xchr(8#130#):='X';
xchr(8#131#):='Y';
xchr(8#132#):='Z';
xchr(8#133#):='[';
xchr(8#134#):='\';
xchr(8#135#):=']';
xchr(8#136#):='^';
xchr(8#137#):='_';@/
xchr(8#140#):='`';
xchr(8#141#):='a';
xchr(8#142#):='b';
xchr(8#143#):='c';
xchr(8#144#):='d';
xchr(8#145#):='e';
xchr(8#146#):='f';
xchr(8#147#):='g';@/
xchr(8#150#):='h';
xchr(8#151#):='i';
xchr(8#152#):='j';
xchr(8#153#):='k';
xchr(8#154#):='l';
xchr(8#155#):='m';
xchr(8#156#):='n';
xchr(8#157#):='o';@/
xchr(8#160#):='p';
xchr(8#161#):='q';
xchr(8#162#):='r';
xchr(8#163#):='s';
xchr(8#164#):='t';
xchr(8#165#):='u';
xchr(8#166#):='v';
xchr(8#167#):='w';@/
xchr(8#170#):='x';
xchr(8#171#):='y';
xchr(8#172#):='z';
xchr(8#173#):='{';
xchr(8#174#):='|';
xchr(8#175#):='}';
xchr(8#176#):='~';@/
xchr(0):=' '; xchr(8#177#):=' '; {these ASCII codes are not used}
 
@ Some of the ASCII codes below \bn{8}{40} have been given symbolic names in
\.{AWEAVE} and \.{ATANGLE} because they are used with a special meaning.
 
@<Types...@>=
@!and_sign : constant ASCII_code:=8#4#; {equivalent to `\.{and}'}
@.and@>
@!not_sign : constant ASCII_code:=8#5#; {equivalent to `\.{not}'}
@.not@>
@!set_element_sign : constant ASCII_code:=8#6#; {equivalent to `\.{in}'}
@.in@>
@!tab_mark : constant ASCII_code:=8#11#; {ASCII code used as tab-skip}
@!line_feed : constant ASCII_code:=8#12#; {ASCII code thrown away at end of line}
@!form_feed : constant ASCII_code:=8#14#; {ASCII code used at end of page}
@!carriage_return : constant ASCII_code:=8#15#; {ASCII code used at end of line}
@!right_arrow : constant ASCII_code:=8#21#; {equivalent to `\.{=>}'}
@.=>@>
@!box_sign : constant ASCII_code:=8#22#; {equivalent to `\.{<>}'}
@.<>@>
@!double_star : constant ASCII_code:=8#23#; {equivalent to `\.{**}'}
@.**@>
@!left_label_bracket:constant ASCII_code:=8#24#; {equivalent to `\.{<<}'}
@.<<@>
@!right_label_bracket:constant ASCII_code:=8#25#; {equivalent to `\.{>>}'}
@.>>@>
@!left_arrow : constant ASCII_code:=8#30#; {equivalent to `\.{:=}'}
@.:=@>
@!not_equal : constant ASCII_code:=8#32#; {equivalent to `\.{/=}'}
@./=@>
@!less_or_equal : constant ASCII_code:=8#34#; {equivalent to `\.{<=}'}
@.<=@>
@!greater_or_equal : constant ASCII_code:=8#35#; {equivalent to `\.{>=}'}
@.>=@>
@!equivalence_sign : constant ASCII_code:=8#36#; {equivalent to `\.{==}'}
@.==@>
@!or_sign : constant ASCII_code:=8#37#; {equivalent to `\.{or}'}
@.or@>
 
@ Here now is the system-dependent part of the character set.
If \.{AWEB} is being implemented on a garden-variety \ADA\ for which
only standard ASCII codes will appear in the input and output files, you
don't need to make any changes here.
@^system dependencies@>
 
Changes to the present module will make \.{AWEB} more friendly on computers
that have an extended character set, so that one can type things like
\.^^Z\ instead of \.{/=}. If you have an extended set of characters that
are easily incorporated into text files, you can assign codes arbitrarily
here, giving an |xchr| equivalent to whatever characters the users of
\.{AWEB} are allowed to have in their input files, provided that unsuitable
characters do not correspond to special codes like |carriage_return|
that are listed above.
 
(The present file \.{AWEAVE.AWEB} does not contain any of the non-ASCII
characters, because it is intended to be used with all implementations of
\.{AWEB}.)
 
@<Set init...@>=
xchr(1..8#37#):=(others => ' ');
 
@ The following system-independent code makes the |xord| array contain a
suitable inverse to the information in |xchr|.
 
@<Set init...@>=
xord:=(others=>8#40#);
for i in 1..8#176# loop xord(xchr(i)):=i;  end loop;
 
@* Input and output.
The input conventions of this program are identical to those of \.{ATANGLE}.
Therefore people who need to make modifications to both systems
should be able to do so without too many headaches.
 
@ Terminal output is done by writing on file |STANDARD_OUTPUT|, which is 
assumed to consist of characters of type |text_char|:
@^system dependencies@>
 
@d new_ln==TEXT_IO.NEW_LINE(TEXT_IO.STANDARD_OUTPUT)
@d print(#)==TEXT_IO.PUT(TEXT_IO.STANDARD_OUTPUT,#) {`|print|' means write on the terminal}
@d print_ln(#)==print(#); new_ln {`|print|' and then start new line}
@d print_nl(#)==new_ln; print(#) {print information starting on a 
                                          new line}
@d print_int(#)==int_number_io.PUT(TEXT_IO.STANDARD_OUTPUT,#) {print out an integer value}

@ The |update_terminal| procedure is called when we want
to make sure that everything we have output to the terminal so far has
actually left the computer's internal buffers and been sent.
(In the \ADA-system used to develop the initial program this is not
required.)
@^system dependencies@>
 
@d update_terminal == null {empty the terminal output buffer}
 

@ The main input comes from |aweb_file|; this input may be overridden
by changes in |change_file|. 
(If |change_file| is empty, there are no changes.)
 
@<Types...@>=
@!aweb_file:text_file; {primary input}
@!change_file:text_file; {updates}
 
@ @<Specification of procedures visible from |input_output|@>=
procedure open_a_file(f:in out text_file;mode_of_file:TEXT_IO.FILE_MODE;
			default_name:STRING;success:out BOOLEAN);
function create_TeX_file(TeX_file_name:STRING)return BOOLEAN;

@ The following code opens a file and returns |TRUE| if succesfully.  
If the file is already open the procedure has no effect; this gives
the ability to open the files by means of the change file, without
changing the \.{AWEB}-file of \.{AWEAVE}.
@^system dependencies@>
 

@<Procedures in |input_output|@>=
procedure @!open_a_file(@!f:in out text_file;
                        @!mode_of_file:TEXT_IO.FILE_MODE;
			@!default_name:STRING;
                        @!success:out BOOLEAN) is
begin if TEXT_IO.IS_OPEN(f) then success:=TRUE;
      else TEXT_IO.OPEN(FILE=>f,MODE=>mode_of_file,NAME=>default_name);
           success:=TRUE;
      end if;
exception
  when TEXT_IO.STATUS_ERROR ! 
       TEXT_IO.NAME_ERROR ! 
       TEXT_IO.USE_ERROR     => success:=FALSE; return;@t\2@>@;
end open_a_file;
 
@ The output goes to |TeX_file|.
 
@<Types...@>=
@!TeX_file: text_file;
 
@ The following code creates |TeX_file|.
@^system dependencies@>
 
@<Procedures in |input_output|@>=
function @!create_TeX_file(@!TeX_file_name:STRING)return BOOLEAN is
begin if TEXT_IO.IS_OPEN(TeX_file) then
        if TEXT_IO.NAME(TeX_file)=TeX_file_name then
          return TRUE;
        else 
          return FALSE;
        end if;
      else TEXT_IO.CREATE(FILE => TeX_file,MODE => TEXT_IO.OUT_FILE,
                          NAME => TeX_file_name);
           return TRUE;
      end if;
exception 
  when TEXT_IO.STATUS_ERROR ! 
       TEXT_IO.NAME_ERROR! 
       TEXT_IO.USE_ERROR      => return FALSE; @t\2@>@;
end create_TeX_file;

@ Input goes into an array called |buffer|.

@<Types...@>=type buffer_type is array(INTEGER range <>)of ASCII_code;
             subtype long_buffer_index is INTEGER range 0..long_buf_size;
             subtype buffer_index is long_buffer_index range 0..buf_size;
             @!buffer: buffer_type(buffer_index);
 
@ The |input_ln| procedure brings the next line of input from the specified
file into the |buffer| array and returns the value |TRUE|, unless the file 
has already been entirely read, in which case it returns |FALSE|. The 
conventions of \TeX\ are followed; i.e., |ASCII_code| numbers representing 
the next line of the file are input into |buffer(0..limit-1)|;
trailing blanks are ignored;
and the global variable |limit| is set to the length of the
@^system dependencies@>
line. The value of |limit| must be strictly less than |buf_size|.
 
We assume that none of the |ASCII_code| values
of |buffer(j)| for |0<=j<limit| is equal to 0, \bn{8}{177}, |line_feed|, 
|form_feed|, or |carriage_return|.

@<Specification of procedures visible from |input_output|@>=
function input_ln(f:text_file) return BOOLEAN; 

@ @<Procedures in |input_output|@>=
function @!input_ln(@!f:text_file) return BOOLEAN is
  {inputs a line or returns |FALSE|}
@!final_limit:buffer_index:=0; {|limit| without trailing blanks}
@!c:text_char;
begin limit:=0;
if not TEXT_IO.IS_OPEN(f) or else TEXT_IO.END_OF_FILE(f) then return FALSE;
else  while not TEXT_IO.END_OF_LINE(f) loop
        TEXT_IO.GET(f,c);
        buffer(limit):=xord(c);
        incr(limit);
        if buffer(limit-1)/=@' ' then final_limit:=limit;
        end if;
        if limit=buf_size then
          TEXT_IO.SKIP_LINE(f);
          decr(limit); {keep |buffer(buf_size)| empty}
          print_nl("! Input line too long"); loc:=0; error; return TRUE;
@.Input line too long@>
      end if;
    end loop;
  TEXT_IO.SKIP_LINE(f); limit:=final_limit; return TRUE;
  end if;
end input_ln;


 
@* Reporting errors to the user.
The \.{AWEAVE} processor operates in three phases: first it inputs the source
file and stores cross-reference data, then it inputs the source once again and
produces the \TeX\ output file, and finally it sorts and outputs the index.
 
The global variables |phase_one| and |phase_three| tell which Phase we are in.
 
@<Types...@>=
@!phase_one: BOOLEAN; {|TRUE| in Phase I, |FALSE| in Phases II and III}
@!phase_three: BOOLEAN; {|TRUE| in Phase III, |FALSE| in Phases I and II}
 
@ The command `|err_print("! Error message")|' will report a syntax error to
the user, by printing the error message at the beginning of a new line and
then giving an indication of where the error was spotted in the source file.
Note that no period follows the error message, since the error routine
will automatically supply a period.
 
The actual error indications are provided by a procedure called |error|.
However, error messages are not actually reported during phase one,
since errors detected on the first pass will be detected again
during the second.
 
@d err_print(#)==
  if not phase_one then
    print_nl(#); error;
  end if@;
 
@<Specification of procedures visible from |input...@>=
procedure error;

@ @<Procedures in |input_output|@>=
procedure @!error is {prints "\.." and location of error message}
@!l:buffer_index; {index into |buffer|}
begin @<Print error location based on input buffer@>;
update_terminal; mark_error;
end error;
 
@ The error locations during Phase I can be indicated by using the global
variables |loc|, |line|, and |changing|, which tell respectively the first
unlooked-at position in |buffer|, the current line number, and whether or not
the current line is from |change_file| or |aweb_file|.
This routine should be modified on systems whose standard text editor
has special line-numbering conventions.
@^system dependencies@>
 
@<Print error location based on input buffer@>=
if changing then 
  print(". (change file ");
else 
  print(". (");
end if;
print("l.");
print_int(line,1);
print_ln(")");
if loc>=limit then l:=limit; else l:=loc; end if;
for k in 1..l loop
  if buffer(k-1)=tab_mark then print(" ");
  else print(xchr(buffer(k-1))); {print the characters already read}
  end if;
end loop;
new_ln;
for k in 1..l loop print(" "); end loop; {space out the next line}
for k in l+1..limit loop print(xchr(buffer(k-1))); end loop;
                  {print the part not yet read}
if buffer(limit)=@'|' then print(xchr(@'|')); end if;
  {end of \ADA\ text in module names}
print(" ")@; {this space separates the message from future asterisks}
 
@ The |jump_out| macro just raises the |end_of_AWEAVE| exception.
It is used when no recovery from a particular error has
been provided.
 
@d jump_out==raise end_of_AWEAVE@;
@d fatal_error(#)==print_nl(#); error; mark_fatal; jump_out@;
 
@<Types...@>=@!end_of_AWEAVE : exception;

@ Sometimes the program's behavior is far different from what it should be,
and \.{AWEAVE} prints an error message that is really for the \.{AWEAVE}
maintenance person, not the user. In such cases the program says
|confusion("indication of where we are")|.
 
@d confusion(#)==fatal_error("! This can't happen ("&#&")")@;
@.This can't happen@>
 
@ An overflow stop occurs if \.{AWEAVE}'s tables aren't large enough.
 
@d overflow(#)==fatal_error("! Sorry, "&#&" capacity exceeded")@;
@.Sorry, x capacity exceeded@>
 
 
@* Data structures.
During the first phase of its processing, \.{AWEAVE} puts identifier names,
index entries, and module names into the large |byte_mem| array, which is
packed with seven-bit integers. Allocation is sequential, since names are
never deleted.
 
An auxiliary array |byte_start| is used as a directory for |byte_mem|,
and the |link|, |ilk|, and |xref| arrays give further information about names.
These auxiliary arrays consist of sixteen-bit items.
 
@<Types...@>=
subtype eight_bits is INTEGER range 0..255; {unsigned one-byte quantity}
subtype sixteen_bits is INTEGER range 0..65_535; {unsigned two-byte quantity}
 
@ \.{AWEAVE} has been designed to avoid the need for indices that are more
than sixteen bits wide, so that it can be used on most computers. But
there are programs that need more than |65_536| bytes; \TeX\ is one of these.
To get around this problem, a slight complication has been added to the
data structures:  |byte_mem| is a two-dimensional array, whose first index
is either 0 or 1. (For generality, the first index is actually allowed to
run between 0 and |ww-1|, where |ww| is defined to be 2; the program will
work for any positive value of |ww|, and it can be simplified in obvious
ways if |ww=1|.)

@<Types...@>= 
@!ww:constant INTEGER :=2; {we multiply the byte capacity by approximately this amount}
subtype w_range is INTEGER range 0..ww-1;
subtype byte_index is INTEGER range 0..max_bytes;
subtype name_index is INTEGER range 0..max_names;
@#
type byte_memory is array (w_range,byte_index) of ASCII_code;
optim pragma PACK(byte_memory); mitpo@;
@#
type name_info is array (name_index) of sixteen_bits;
@#
@!byte_mem: byte_memory;{characters of names}
@!byte_start: name_info;{directory into |byte_mem|}
@!link: name_info; {hash table or tree links}
@!ilk: name_info; {type codes or tree links}
@!xref: name_info; {heads of cross-reference lists}
 
@ The names of identifiers are found by computing a hash address |h| and
then looking at strings of bytes signified by |hash(h)|, |link(hash(h))|,
|link(link(hash(h)))|, \dots, until either finding the desired name
or encountering a zero.
 
A `|name_pointer|' variable, which signifies a name, is an index into
|byte_start|. The actual sequence of characters in the name pointed to by
|p| appears in positions |byte_start(p)| to |byte_start(p+ww)-1|, inclusive,
in the segment of |byte_mem| whose first index is |p mod ww|. Thus, when
|ww=2| the even-numbered name bytes appear in |byte_mem(0,@t$*$@>)|
and the odd-numbered ones appear in |byte_mem(1,@t$*$@>)|.
The pointer 0 is used for undefined module names; we don't
want to use it for the names of identifiers, since 0 stands for a null
pointer in a linked list.
 
We usually have |byte_start(name_ptr+w)=byte_ptr((name_ptr+w) mod ww)|
for |0<=w<ww|, since these are the starting positions for the next |ww|
names to be stored in |byte_mem|.
 
@d length(#)==byte_start(#+ww)-byte_start(#) {the length of a name}
@d null_array==(others=>0) {all elements have value 0}
 
@<Types...@>=
subtype name_pointer is name_index; {identifies a name}
@#
@!name_ptr:name_pointer:=1; {first unused position in |byte_start|}
@!byte_ptr:array (w_range) of byte_index :=null_array;
  {first unused position in |byte_mem|}
 
@ @<Set init...@>=
byte_start(0..ww):=null_array; 
 
@ Several types of identifiers are distinguished by their |ilk|:
 
\yskip\hang |normal| identifiers are part of the \ADA\ program and
will appear in italic type.
 
\yskip\hang |predefined| identifiers are part of the \ADA\ program and
will appear like `|INTEGER|'.

\yskip\hang |roman| identifiers are index entries that appear after
\.{@@\^} in the \.{AWEB} file.
@.\AT!\^@>
 
\yskip\hang |wildcard| identifiers are index entries that appear after
\.{@@:} in the \.{AWEB} file.
@.\AT!:@>
 
\yskip\hang |italic| identifiers are index entries that appear after
\.{@@i} in the \.{AWEB} file.
@.\AT!i@> 

\yskip\hang |bold_face| identifiers are index entries that appear after
\.{@@b} in the \.{AWEB} file.
@.\AT!b@> 

\yskip\hang |slanted| identifiers are index entries that appear after
\.{@@s} in the \.{AWEB} file.
@.\AT!s@> 

\yskip\hang |typewriter| identifiers are index entries that appear after
\.{@@.} in the \.{AWEB} file.
@.\AT!.@>
 
\yskip\hang |accept_like|, |and_like|, \dots, |with_like|
identifiers are \ADA\ reserved words whose |ilk| explains how they are
to be treated when \ADA\ code is being formatted.
 
@d reserved(#)==(ilk(#)>predefined) {tells if a name is a reserved word}
@d defined(#)==(ilk(#)>typewriter) {tells if a name is predefined or reserved}

@<Types...@>=
@!normal:constant INTEGER:=0; {ordinary identifiers have |normal| ilk}
@!roman:constant INTEGER:=1; {normal index entries have |roman| ilk}
@!wildcard:constant INTEGER:=2; {user-formatted index entries have |wildcard| ilk}
@!italic:constant INTEGER:=3; {`italic-type' entries have |italic| ilk}
@!bold_face:constant INTEGER:=4; {`boldface-type' entries have |bold_face| ilk}
@!slanted:constant INTEGER:=5; {`slanted-type' entries have |slanted| ilk}
@!typewriter:constant INTEGER:=6; {`typewriter type' entries have |typewriter| ilk}
@!predefined:constant INTEGER:=7; {predefined identifiers have |predefined| ilk}
@!accept_like:constant INTEGER:=8; {\&{accept}}
@!all_like:constant INTEGER:=9; {\&{all}, \&{null}, \&{terminate}}
@!and_like:constant INTEGER:=10; {\&{and}}
@!array_like:constant INTEGER:=11; {\&{array}}
@!at_like:constant INTEGER:=12; {\&{at}}
@!begin_like:constant INTEGER:=13; {\&{begin}, \&{select}}
@!body_like:constant INTEGER:=14; {\&{body}}
@!case_like:constant INTEGER:=15; {\&{case}}
@!declare_like:constant INTEGER:=16; {\&{declare}}
@!else_like:constant INTEGER:=17; {\&{else}}
@!elsif_like:constant INTEGER:=18; {\&{elsif}}
@!end_like:constant INTEGER:=19; {\&{end}}
@!exception_like: constant INTEGER:=20; {\&{exception}}
@!generic_like:constant INTEGER:=21; {\&{generic}}
@!goto_like:constant INTEGER:=22; {\&{abort}, \dots, \&{while}, if not stated
                                    otherwise}
@!if_like:constant INTEGER:=23; {\&{if}}
@!in_like:constant INTEGER:=24; {\&{in}}
@!is_like:constant INTEGER:=25; {\&{do}, \&{is}}
@!loop_like:constant INTEGER:=26; {\&{loop}}
@!mod_like:constant INTEGER:=27; {\&{mod}, \&{rem}, \&{xor}}
@!new_like:constant INTEGER:=28; {\&{new}}
@!not_like:constant INTEGER:=29; {\&{not}}
@!of_like:constant INTEGER:=30; {\&{of}}
@!or_like:constant INTEGER:=31; {\&{or}}
@!pragma_like:constant INTEGER:=32; {\&{pragma}}
@!private_like:constant INTEGER:=33; {\&{private}}
@!proc_like:constant INTEGER:=34; {\&{entry}, \&{function}, \&{package},
                                   \&{procedure}, \&{task}}
@!range_like:constant INTEGER:=35; {\&{range}}
@!record_like:constant INTEGER:=36; {\&{record}}
@!return_like:constant INTEGER:=37; {\&{return}, \&{exit}}
@!separate_like:constant INTEGER:=38; {\&{separate}}
@!then_like:constant INTEGER:=39; {\&{then}}
@!type_like:constant INTEGER:=40; {\&{subtype}, \&{type}, \&{for}}
@!when_like:constant INTEGER:=41; {\&{when}}
@!with_like:constant INTEGER:=42; {\&{use}, \&{with}}
@rabort@>
@rabs@>
@raccept@>
@raccess@>
@rall@>
@rand@>
@rarray@>
@rat@>
@rbegin@>
@rbody@>
@rcase@>
@rconstant@>
@rdeclare@>

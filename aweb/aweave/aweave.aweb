@rexit@>
@rfor@>
@rfunction@>
@rgeneric@>
@rgoto@>
@rif@>
@rin@>
@ris@>
@rlimited@>
@rloop@>
@rmod@>
@rnew@>
@rnot@>
@rnull@>
@rof@>
@ror@>
@rothers@>
@rout@>
@rpackage@>
@rpragma@>
@rprivate@>
@rprocedure@>
@rraise@>
@rrange@>
@rrecord@>
@rrem@>
@rrenames@>
@rreturn@>
@rreverse@>
@rselect@>
@rseparate@>
@rsubtype@>
@rtask@>
@rterminate@>
@rthen@>
@rtype@>
@ruse@>

PROCEDURE PRINT_ID(P:NAME_POINTER)IS W:W_RANGE;
BEGIN IF P>=NAME_PTR THEN TEXT_IO.PUT(TEXT_IO.STANDARD_OUTPUT,
"IMPOSSIBLE");ELSE W:=P MOD WW;
FOR K IN BYTE_START(P)..BYTE_START(P+WW)-1 LOOP TEXT_IO.PUT(TEXT_IO.
STANDARD_OUTPUT,XCHR(BYTE_MEM(W,K)));END LOOP;END IF;END PRINT_ID;
--{:49}{54:}
PROCEDURE NEW_XREF(P:NAME_POINTER)IS Q:XREF_NUMBER;M,N:SIXTEEN_BITS;
BEGIN IF((ILK(P)>PREDEFINED)OR(BYTE_START(P)+1=BYTE_START(P+WW)))AND(
XREF_SWITCH=0)THEN RETURN;END IF;M:=MODULE_COUNT+XREF_SWITCH;
XREF_SWITCH:=0;Q:=XREF(P);IF Q>0 THEN N:=XMEM(Q).NUM_FIELD;
IF(N=M)OR(N-DEF_FLAG=M)OR(N-BODY_FLAG=M)THEN RETURN;
ELSIF(M-DEF_FLAG=N)OR(M-BODY_FLAG=N)THEN XMEM(Q).NUM_FIELD:=M;RETURN;
END IF;END IF;
IF XREF_PTR=MAX_REFS THEN TEXT_IO.NEW_LINE(TEXT_IO.STANDARD_OUTPUT);
TEXT_IO.PUT(TEXT_IO.STANDARD_OUTPUT,"! Sorry, "&"cross reference"&
" capacity exceeded");ERROR;HISTORY:=FATAL_MESSAGE;RAISE END_OF_AWEAVE;
ELSE XREF_PTR:=XREF_PTR+1;XMEM(XREF_PTR).NUM_FIELD:=M;END IF;
XMEM(XREF_PTR).XLINK_FIELD:=Q;XREF(P):=XREF_PTR;END NEW_XREF;
--{:54}{55:}
PROCEDURE NEW_MOD_XREF(P:NAME_POINTER)IS Q,R:XREF_NUMBER;
BEGIN Q:=XREF(P);R:=0;
IF Q>0 THEN IF MOD_XREF_SWITCH=0 THEN WHILE XMEM(Q).NUM_FIELD>=DEF_FLAG
LOOP R:=Q;Q:=XMEM(Q).XLINK_FIELD;END LOOP;
ELSIF XMEM(Q).NUM_FIELD>=DEF_FLAG THEN R:=Q;Q:=XMEM(Q).XLINK_FIELD;
END IF;END IF;
IF XREF_PTR=MAX_REFS THEN TEXT_IO.NEW_LINE(TEXT_IO.STANDARD_OUTPUT);
TEXT_IO.PUT(TEXT_IO.STANDARD_OUTPUT,"! Sorry, "&"cross reference"&
" capacity exceeded");ERROR;HISTORY:=FATAL_MESSAGE;RAISE END_OF_AWEAVE;
ELSE XREF_PTR:=XREF_PTR+1;
XMEM(XREF_PTR).NUM_FIELD:=MODULE_COUNT+MOD_XREF_SWITCH;END IF;
XMEM(XREF_PTR).XLINK_FIELD:=Q;MOD_XREF_SWITCH:=0;
IF R=0 THEN XREF(P):=XREF_PTR;ELSE XMEM(R).XLINK_FIELD:=XREF_PTR;END IF;
END NEW_MOD_XREF;--{:55}

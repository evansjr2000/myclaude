PROCEDURE AWEAVE IS AC:INTEGER:=0;IC:INTEGER:=0;YR_OUTPUT_FILE:USTRING;
BEGIN TEXT_IO.PUT(TEXT_IO.STANDARD_OUTPUT,"Trying to open input file.");
TEXT_IO.NEW_LINE(TEXT_IO.STANDARD_OUTPUT);AC:=ARGUMENT_COUNT;
IF AC<1 THEN TEXT_IO.NEW_LINE(TEXT_IO.STANDARD_OUTPUT);
TEXT_IO.PUT(TEXT_IO.STANDARD_OUTPUT,"No file on command line");ERROR;
HISTORY:=FATAL_MESSAGE;RAISE END_OF_AWEAVE;END IF;
OPEN_A_FILE(AWEB_FILE,TEXT_IO.IN_FILE,ARGUMENT(1),OPENED);
IF NOT OPENED THEN TEXT_IO.NEW_LINE(TEXT_IO.STANDARD_OUTPUT);
TEXT_IO.PUT(TEXT_IO.STANDARD_OUTPUT,"AWEB file not open");ERROR;
HISTORY:=FATAL_MESSAGE;RAISE END_OF_AWEAVE;END IF;OPENED:=FALSE;
IF AC>=2 THEN OPEN_A_FILE(CHANGE_FILE,TEXT_IO.IN_FILE,ARGUMENT(2),OPENED

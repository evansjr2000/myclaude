TEXT_IO.PUT(TEXT_IO.STANDARD_OUTPUT,"! No change file.");
TEXT_IO.NEW_LINE(TEXT_IO.STANDARD_OUTPUT);END IF;
IC:=INDEX(U(ARGUMENT(1)),".");
IF IC=0 THEN YR_OUTPUT_FILE:=U(ARGUMENT(1))&".tex";
ELSE YR_OUTPUT_FILE:=U(ARGUMENT(1));OVERWRITE(YR_OUTPUT_FILE,IC,".tex");
ADA.STRINGS.UNBOUNDED.HEAD(YR_OUTPUT_FILE,IC+3);END IF;
--OPEN_A_FILE(TEX_FILE,TEXT_IO.OUT_FILE,"aweb_output.tex",OPENED);
OPEN_A_FILE(TEX_FILE,TEXT_IO.OUT_FILE,S(YR_OUTPUT_FILE),OPENED);

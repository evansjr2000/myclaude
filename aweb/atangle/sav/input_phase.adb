WHEN OTHERS=>RETURN IGNORE;END CASE;END CONTROL_CODE;--{:132}{133:}
FUNCTION SKIP_AHEAD RETURN EIGHT_BITS IS C:EIGHT_BITS;
BEGIN LOOP IF LOC>LIMIT THEN GET_LINE;

IF LOC<=LIMIT THEN LOC:=LOC+2;C:=CONTROL_CODE(BUFFER(LOC-1));
IF(C/=IGNORE)OR(BUFFER(LOC-1)=62)THEN RETURN C;END IF;END IF;END LOOP;
END SKIP_AHEAD;--{:133}{134:}
PROCEDURE SKIP_COMMENT IS BAL:EIGHT_BITS:=0;C:ASCII_CODE;
